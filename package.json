{
  "name": "cropo",
  "version": "0.6.0",
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "mohammad h alijany",
  "license": "MIT",
  "source": "./script.ts",
  "type": "module",
  "main": "./dist/script.cjs",
  "module": "./dist/script.js",
  "types": "./dist/script.d.ts",
  "unpkg": "./dist/script.global.js",
  "jsdelivr": "./dist/script.global.js",
  "exports": {
    ".": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js",
      "require": "./dist/script.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "description": "Cropo is a fast, lightweight image cropping tools for JavaScript. Resize and crop your uploaded image using a intuitive user interface.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alijany/cropo.git"
  },
  "keywords": [
    "canvas",
    "image-processing",
    "profile-image",
    "crop",
    "zoom-images",
    "image-zoom",
    "cropper",
    "zoom",
    "crop-image",
    "image-cropper",
    "pinch-to-zoom",
    "image-crop",
    "cropping",
    "cropper"
  ],
  "bugs": {
    "url": "https://github.com/alijany/cropo/issues"
  },
  "homepage": "https://github.com/alijany/cropo#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
